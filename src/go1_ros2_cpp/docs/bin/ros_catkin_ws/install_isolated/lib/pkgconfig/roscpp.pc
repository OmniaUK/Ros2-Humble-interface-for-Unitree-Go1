prefix=/home/pi/ros_catkin_ws/install_isolated

Name: roscpp
Description: Description of roscpp
Version: 1.14.5
Cflags: -I${prefix}/include -I/usr/include
Libs: -L${prefix}/lib -lroscpp /usr/lib/aarch64-linux-gnu/libboost_chrono.so /usr/lib/aarch64-linux-gnu/libboost_filesystem.so /usr/lib/aarch64-linux-gnu/libboost_system.so
Requires: cpp_common message_runtime rosconsole roscpp_serialization roscpp_traits rosgraph_msgs rostime std_msgs xmlrpcpp
