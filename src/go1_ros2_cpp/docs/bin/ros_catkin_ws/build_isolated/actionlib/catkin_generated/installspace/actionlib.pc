prefix=/opt/ros/melodic

Name: actionlib
Description: Description of actionlib
Version: 1.12.0
Cflags: -I${prefix}/include -I/usr/include
Libs: -L${prefix}/lib -lactionlib /usr/lib/aarch64-linux-gnu/libboost_thread.so -pthread /usr/lib/aarch64-linux-gnu/libboost_chrono.so /usr/lib/aarch64-linux-gnu/libboost_system.so /usr/lib/aarch64-linux-gnu/libboost_date_time.so /usr/lib/aarch64-linux-gnu/libboost_atomic.so
Requires: actionlib_msgs message_runtime roscpp std_msgs
